# 로컬 MariaDB (복사 후 .env 로 저장)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=attend
DB_PASSWORD=
# 로컬 예: attend · Railway 운영 예: gs_attend (MYSQL_DATABASE / DB_NAME 과 동일하게)
DB_NAME=attend

# FastAPI(uvicorn) 기본 포트 — client 에서 npm run dev:api 와 맞출 것
API_PORT=8000

# 모바일 JWT (운영에서는 강한 임의 문자열로 설정)
# JWT_SECRET=
# ACCESS_TOKEN_EXPIRE_MINUTES=60
# REFRESH_TOKEN_EXPIRE_DAYS=14
